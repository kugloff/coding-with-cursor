# Copy this file to .env and fill in your key.
# server/.env is gitignored — do not commit real secrets.

GEMINI_API_KEY=

# Optional overrides:
# PORT=3001
# CLIENT_ORIGIN=http://localhost:5173
# RUN_VM_TIMEOUT_MS=1000
# Python subprocess (POST /run when runtime is "python"):
# RUN_PYTHON_TIMEOUT_MS=1000
# PYTHON_BIN=py
# Black formatter (POST /format when environment is "python"):
# Install: py -m pip install black
# Server tries: black, then PYTHON_BIN -m black, then py -m black / python -m black (Windows).
# FORMAT_PYTHON_TIMEOUT_MS=15000
# BLACK_BIN=black
# BLACK_BIN=py -m black
