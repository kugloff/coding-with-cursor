# Copy this file to .env and fill in your key.
# server/.env is gitignored — do not commit real secrets.

GEMINI_API_KEY=

# Optional overrides:
# PORT=3001
# CLIENT_ORIGIN=http://localhost:5173
# RUN_VM_TIMEOUT_MS=5000
# Python subprocess (POST /run when runtime is "python"):
# RUN_PYTHON_TIMEOUT_MS=5000
# PYTHON_BIN=py
# Black formatter (POST /format when environment is "python"):
# Install: py -m pip install black
# Server tries: black, then PYTHON_BIN -m black, then py -m black / python -m black (Windows).
# FORMAT_PYTHON_TIMEOUT_MS=15000
# BLACK_BIN=black
# BLACK_BIN=py -m black
# CSharpier formatter (POST /format when environment is "csharp"):
# Install: dotnet tool install -g csharpier
# Server tries: csharpier, then dotnet csharpier, then dotnet tool run csharpier (Windows).
# FORMAT_CSHARP_TIMEOUT_MS=15000
# CSHARPIER_BIN=csharpier
# CSHARPIER_BIN=dotnet csharpier format
# C# run (POST /run when environment is "csharp"):
# Requires .NET SDK (dotnet on PATH). Temp console project + dotnet run.
# RUN_CSHARP_TIMEOUT_MS=5000
# DOTNET_TFM=net8.0
# DOTNET_BIN=dotnet
